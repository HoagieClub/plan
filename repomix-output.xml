@media (hover: hover) {
	.Action:hover {
		background-color: var(--action-background, rgba(0, 0, 0, 0.05));
	}

	.Action:hover svg {
		fill: #ffffff; /* The fill of handle and remove button on hover. This corresponds to tailwind gray-500 */
	}
}

.Action:active {
	background-color: var(--background, rgba(0, 0, 0, 0.05));
}

.Action:active svg {
	fill: #ffffff; /* The fill of handle and remove button "ghost" when dragging */
}

.Action:focus-visible {
