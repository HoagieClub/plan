export const ProfileCard: FC<ProfileCardProps> = ({ user, onSettingsClick }) => {
	const theme = hoagiePlan;
	const name = user.name;
	const email = user.email ?? (user.sub.includes('@') ? user.sub.split('|').pop() : 'N/A');

