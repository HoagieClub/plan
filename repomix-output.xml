										}}
									/>
									<span className='ml-2 text-sm font-medium text-gray-800'>{level}</span>
								</div>
							))}
						</div>
					</div>
					<div>
						<FormLabel>Allowed grading</FormLabel>
						<div className='grid grid-cols-3'>
							{grading.map((grading) => (
								<div key={grading} className='mb-2 flex items-center'>
									<Checkbox
										size='sm'
										id={`grading-${grading}`}
