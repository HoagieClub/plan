    def pretty_print(data, indent=0):
        for key, value in data.items():
            print("  " * indent + str(key))
            if isinstance(value, dict):
                pretty_print(value, indent + 1)
            else:
                print("  " * (indent + 1) + str(value))

    return JsonResponse(formatted_dict)


